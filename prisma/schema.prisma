generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FeedArticle {
  id            String   @id
  slug          String   @unique
  title         String
  excerpt       String
  /// Полный текст публикации (в БД колонка `text` — имя `text` зарезервировано в API Prisma)
  body          String   @default("") @map("text")
  publishedAt   DateTime
  gridCol       Int
  gridRow       Int
  /// Обложка поста (JPEG/PNG и т.д.)
  coverImage    Bytes?
  coverImageAlt String?
  /// Показывать обложку в ленте на главной
  showCoverOnHome Boolean @default(false)

  @@map("feed_articles")
}
